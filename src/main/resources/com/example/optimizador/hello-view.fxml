<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import java.net.URL?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="650.0" prefWidth="950.0" spacing="25.0" styleClass="main-container" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.optimizador.HelloController">
    <padding>
        <Insets bottom="35.0" left="45.0" right="45.0" top="35.0" />
    </padding>

    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>

    <HBox alignment="CENTER_LEFT" spacing="20.0">
        <children>
            <Label styleClass="title-label" text="Optimizador de Código" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="btn_limpiar" mnemonicParsing="false" styleClass="btn-secondary" text="Limpiar" />
            <Button fx:id="btn_optimizar" mnemonicParsing="false" styleClass="btn-primary" text="Optimizar" />
        </children>
    </HBox>

    <HBox spacing="35.0" VBox.vgrow="ALWAYS">
        <children>
            <VBox spacing="12.0" HBox.hgrow="ALWAYS">
                <children>
                    <Label styleClass="section-label" text="Código Original" />
                    <TextArea fx:id="txa_codigo" styleClass="custom-text-area" VBox.vgrow="ALWAYS" />
                </children>
            </VBox>

            <VBox spacing="12.0" HBox.hgrow="ALWAYS">
                <children>
                    <Label styleClass="section-label" text="Resultado Optimizado" />
                    <TextArea fx:id="txa_resultado" editable="false" styleClass="custom-text-area" VBox.vgrow="ALWAYS" />
                </children>
            </VBox>
        </children>
    </HBox>
</VBox>